.article-page {
  padding-bottom: 20px;
}

.article-title {
  font-size: 20px;
  font-weight: bold;
  text-align: center;
  margin-bottom: 8px;
  line-height: 1.4;
}

.article-meta {
  font-size: 12px;
  color: #999;
  text-align: center;
  margin-bottom: 4px;
}

.article-content {
  line-height: 1.8;
  overflow-x: hidden;
}

.tip {
  margin-top: 20px;
  background: #f0faf4;
  border-radius: 8px;
  padding: 15px;
  font-size: 13px;
  color: #666;
  line-height: 2;
}
