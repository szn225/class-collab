.login-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #07c160 0%, #089a4e 100%);
}

.login-box {
  background: #fff;
  border-radius: 16px;
  padding: 40px 30px;
  width: 85%;
  max-width: 350px;
  text-align: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.logo {
  font-size: 48px;
  margin-bottom: 10px;
}

.title {
  font-size: 24px;
  font-weight: bold;
  color: #333;
  margin-bottom: 6px;
}

.subtitle {
  font-size: 14px;
  color: #999;
  margin-bottom: 30px;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.input {
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 12px 15px;
  font-size: 16px;
  text-align: center;
}

.hint {
  margin-top: 20px;
  font-size: 12px;
  color: #bbb;
}
